# Raw data (too large for git — see README for download instructions)
echo-poc/data/raw/

# Processed data (regeneratable from raw)
echo-poc/data/processed/

# Publisher PDFs staged for G2 anchor reading — copyrighted,
# obtained via Open University Library access. Redistribution rights
# not held. Reproducers must obtain these independently; provenance
# captured in phase1b/refs/README.md and phase1b/refs/anchor_reads/.
echo-poc/phase1b/refs/*.pdf
echo-poc/phase1b/refs/*.docx

# Model outputs (regeneratable)
echo-poc/outputs/models/
echo-poc/outputs/figures/
echo-poc/outputs/metrics/
echo-poc/outputs/export/
echo-poc/outputs/write-up/

# Keep gate results trackable but not required
# echo-poc/outputs/gates/

# Phase 1b λ-search per-rep training histories. The main result JSON
# (`lambda_search_f2_result.json`) captures all decision-relevant data
# (per-rep final-window means, dominance flags, val losses, physics
# fractions). The per-epoch full training trajectories in
# per_rep_histories/ are diagnostic-only (~150 MB) and regeneratable by
# re-running F-2; excluded from git to keep repo size bounded. The
# directory remains on disk locally as the F-2 resume / re-classification
# source artefact.
echo-poc/phase1b/lambda_search/results/per_rep_histories/

